# ── OT Observability Lab — central variables (single source) ───────────────
# Copy to .env and adjust. docker-compose and the Python tooling both read this.

# --- Postgres backing store ---
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=zabbix
POSTGRES_DB=zabbix

# --- Zabbix server / web ---
ZBX_WEB_PORT=8080
ZBX_TRAPPER_PORT=10051
PHP_TZ=Asia/Jakarta
ZBX_TIMEZONE=Asia/Jakarta

# --- Zabbix API (used by provisioning IaC) ---
# Default frontend credentials of a fresh Zabbix install:
ZBX_API_URL=http://127.0.0.1:8080
ZBX_API_USER=Admin
ZBX_API_PASSWORD=zabbix

# --- Trapper sender (used by the OT simulators) ---
ZBX_SENDER_HOST=127.0.0.1
ZBX_SENDER_PORT=10051

# --- Simulation tuning (the "calibration knob" for the mock plant) ---
# STICKINESS: probability a parameter keeps its current health state each tick.
# Higher = longer Good/Underperform/Failed stretches (smoother curves for ML).
SIM_STICKINESS=0.30
# Global time compression: 1.0 = real catalog intervals, 10.0 = 10x faster demo.
SIM_TIME_SCALE=1000.0
